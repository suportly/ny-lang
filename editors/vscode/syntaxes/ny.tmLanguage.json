{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Ny",
  "scopeName": "source.ny",
  "patterns": [
    { "include": "#comments" },
    { "include": "#fstrings" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#function-def" },
    { "include": "#keywords" },
    { "include": "#builtins" },
    { "include": "#types" },
    { "include": "#function-call" },
    { "include": "#operators" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        { "name": "comment.line.double-slash.ny", "match": "//.*$" },
        { "name": "comment.block.ny", "begin": "/\\*", "end": "\\*/", "patterns": [
          { "include": "#comments" }
        ]}
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.ny",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            { "name": "constant.character.escape.ny", "match": "\\\\[nrt\\\\\"0]" }
          ]
        }
      ]
    },
    "fstrings": {
      "patterns": [
        {
          "name": "string.interpolated.ny",
          "begin": "f\"",
          "end": "\"",
          "patterns": [
            { "name": "constant.character.escape.ny", "match": "\\\\[nrt\\\\\"0]" },
            {
              "name": "meta.embedded.expression.ny",
              "begin": "\\{",
              "end": "\\}",
              "beginCaptures": { "0": { "name": "punctuation.definition.interpolation.begin.ny" } },
              "endCaptures": { "0": { "name": "punctuation.definition.interpolation.end.ny" } },
              "patterns": [
                { "include": "source.ny" }
              ]
            }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        { "name": "constant.numeric.float.ny", "match": "\\b[0-9]+\\.[0-9]+\\b" },
        { "name": "constant.numeric.hex.ny", "match": "\\b0x[0-9a-fA-F]+\\b" },
        { "name": "constant.numeric.integer.ny", "match": "\\b[0-9]+\\b" }
      ]
    },
    "function-def": {
      "patterns": [
        {
          "match": "\\b(fn)\\s+([a-zA-Z_][a-zA-Z0-9_]*)",
          "captures": {
            "1": { "name": "keyword.declaration.ny" },
            "2": { "name": "entity.name.function.definition.ny" }
          }
        }
      ]
    },
    "keywords": {
      "patterns": [
        { "name": "keyword.control.ny", "match": "\\b(if|else|while|for|in|return|break|continue|loop|match|defer)\\b" },
        { "name": "keyword.declaration.ny", "match": "\\b(fn|struct|enum|trait|impl|use|mod|extern|let|pub|unsafe)\\b" },
        { "name": "constant.language.ny", "match": "\\b(true|false)\\b" },
        { "name": "keyword.operator.word.ny", "match": "\\b(as)\\b" }
      ]
    },
    "builtins": {
      "patterns": [
        {
          "name": "support.function.builtin.ny",
          "match": "\\b(print|println|alloc|free|sizeof|vec_new|map_new|map_insert|map_get|map_contains|map_len|fopen|fclose|fwrite_str|fread_byte|read_line|int_to_str|str_to_int|to_str|exit|sleep_ms|clock_ms|str_split_count|str_split_get|arena_new|arena_alloc|arena_free|arena_reset|arena_bytes_used|thread_spawn|thread_join|channel_new|channel_send|channel_recv|channel_close|pool_new|pool_submit|pool_wait|pool_free|simd_splat_f32x4|simd_splat_f32x8|simd_reduce_add_f32)\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        { "name": "storage.type.primitive.ny", "match": "\\b(i8|i16|i32|i64|i128|u8|u16|u32|u64|u128|f32|f64|bool|str)\\b" },
        { "name": "storage.type.simd.ny", "match": "\\b(f32x4|f32x8|f64x2|f64x4|i32x4|i32x8)\\b" },
        { "name": "storage.type.generic.ny", "match": "\\b(Vec|HashMap|Option|Result)\\b" },
        { "name": "entity.name.type.ny", "match": "\\b[A-Z][a-zA-Z0-9_]*\\b" }
      ]
    },
    "function-call": {
      "patterns": [
        { "name": "entity.name.function.ny", "match": "\\b([a-z_][a-z0-9_]*)\\s*(?=\\()" }
      ]
    },
    "operators": {
      "patterns": [
        { "name": "keyword.operator.arrow.ny", "match": "=>|->" },
        { "name": "keyword.operator.assignment.ny", "match": ":=|:~=|:~|\\+=|-=|\\*=|/=|%=|&=|\\|=|\\^=|<<=|>>=" },
        { "name": "keyword.operator.namespace.ny", "match": "::" },
        { "name": "keyword.operator.misc.ny", "match": "\\?|\\.\\.=|\\.\\." }
      ]
    }
  }
}
