{
  "scopeName": "source.ny",
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#keywords" },
    { "include": "#types" },
    { "include": "#functions" },
    { "include": "#operators" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        { "name": "comment.line.double-slash.ny", "match": "//.*$" },
        { "name": "comment.block.ny", "begin": "/\\*", "end": "\\*/" }
      ]
    },
    "strings": {
      "patterns": [
        { "name": "string.quoted.double.ny", "begin": "\"", "end": "\"", "patterns": [
          { "name": "constant.character.escape.ny", "match": "\\\\." }
        ]}
      ]
    },
    "numbers": {
      "patterns": [
        { "name": "constant.numeric.float.ny", "match": "\\b[0-9]+\\.[0-9]+\\b" },
        { "name": "constant.numeric.integer.ny", "match": "\\b[0-9]+\\b" }
      ]
    },
    "keywords": {
      "patterns": [
        { "name": "keyword.control.ny", "match": "\\b(if|else|while|for|in|return|break|continue|loop|match|defer)\\b" },
        { "name": "keyword.declaration.ny", "match": "\\b(fn|struct|enum|trait|impl|use|mod|extern|let|pub|unsafe)\\b" },
        { "name": "constant.language.ny", "match": "\\b(true|false)\\b" },
        { "name": "keyword.operator.ny", "match": "\\b(as)\\b" }
      ]
    },
    "types": {
      "patterns": [
        { "name": "storage.type.ny", "match": "\\b(i8|i16|i32|i64|i128|u8|u16|u32|u64|u128|f32|f64|bool|str|f32x4|f32x8|f64x2|f64x4|i32x4|i32x8)\\b" },
        { "name": "entity.name.type.ny", "match": "\\b[A-Z][a-zA-Z0-9_]*\\b" }
      ]
    },
    "functions": {
      "patterns": [
        { "name": "entity.name.function.ny", "match": "\\b([a-z_][a-z0-9_]*)\\s*(?=\\()" }
      ]
    },
    "operators": {
      "patterns": [
        { "name": "keyword.operator.ny", "match": "=>|->|:=|:~=|::|:~|\\?|\\.\\.=|\\.\\." }
      ]
    }
  }
}
